# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# VirusTotal
VIRUSTOTAL_API_KEY=your_virustotal_api_key

# Bot Configuration
BOT_MODE=polling          # "polling" for dev, "webhook" for production
WEBHOOK_URL=              # Required when BOT_MODE=webhook (e.g., https://your-app.up.railway.app)
PORT=3000                 # Express server port

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_UNLIMITED_PRICE_ID=price_...
STRIPE_ABYSSAL_ACTIVE_PRICE_ID=price_...  # $0/mo — commission-only, billing via attack events

# Threat-Intel Shared DB (WS1/WS2 — harvest high-risk content)
# Project: threat-intel (kociyrlnqlnqxgwqvvga)
# Dashboard: https://supabase.com/dashboard/project/kociyrlnqlnqxgwqvvga/settings/api
THREAT_INTEL_URL=https://kociyrlnqlnqxgwqvvga.supabase.co
THREAT_INTEL_SERVICE_KEY=     # service_role key (secret — never expose)
THREAT_INTEL_RISK_THRESHOLD=7 # risk score 1-10; >= this fires intercept
INTERCEPT_USER_HASH_SALT=     # optional — salt for sha256 of user_id

# Internal Scan (WS5 — shared secret for Discord bot / Flutter backend to call /internal/scan)
INTERNAL_SCAN_SECRET=         # random 32+ bytes; shared with scamshield-discord bot
